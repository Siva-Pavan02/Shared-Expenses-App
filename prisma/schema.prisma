generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  name             String
  passwordHash     String
  groupMemberships GroupMember[]
  expensesPaid     Expense[]
  expenseShares      ExpenseParticipant[]
  sentSettlements    Settlement[]         @relation("SentSettlements")
  rcvdSettlements    Settlement[]         @relation("RcvdSettlements")
  createdSettlements Settlement[]         @relation("CreatedSettlements")
  reviewedAnomalies  ImportAnomaly[]      @relation("ReviewedAnomalies")
}

model Group {
  id           String        @id @default(uuid())
  name         String
  baseCurrency String        @default("INR")
  createdAt    DateTime      @default(now())
  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  importJobs   ImportJob[]
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  isAdmin  Boolean   @default(false)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, joinedAt, leftAt])
}

model Expense {
  id           String               @id @default(uuid())
  groupId      String
  paidById     String
  amount       Decimal
  currency     String
  exchangeRate Decimal              @default(1.0)
  convertedAmount Decimal           @default(0)
  description  String
  date         DateTime
  splitType    String               // "EQUAL", "UNEQUAL", "PERCENTAGE", "SHARE"
  createdAt    DateTime             @default(now())
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User                 @relation(fields: [paidById], references: [id], onDelete: Restrict)
  participants ExpenseParticipant[]

  @@index([groupId, date])
  @@index([date])
}

model ExpenseParticipant {
  id                String  @id @default(uuid())
  expenseId         String
  userId            String
  splitValue        Decimal? // The raw input (e.g., 3 shares, 20 percent). Null for EQUAL.
  computedOweAmount Decimal  // The calculated final amount owed for this expense
  expense           Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([expenseId, userId])
  @@index([userId])
}

model Settlement {
  id           String   @id @default(uuid())
  groupId      String
  fromUserId   String
  toUserId     String
  amount       Decimal
  currency     String
  exchangeRate Decimal  @default(1.0)
  convertedAmount Decimal @default(0)
  date         DateTime
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  createdById  String
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser     User     @relation("SentSettlements", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser       User     @relation("RcvdSettlements", fields: [toUserId], references: [id], onDelete: Restrict)
  createdBy    User     @relation("CreatedSettlements", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([date])
}

model ImportJob {
  id        String          @id @default(uuid())
  groupId   String
  filename  String
  status    String          // "PENDING_REVIEW", "COMPLETED", "FAILED"
  createdAt DateTime        @default(now())
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  anomalies ImportAnomaly[]
  rows      ImportRow[]

  @@index([createdAt])
}

model ImportRow {
  id               String    @id @default(uuid())
  importJobId      String
  rowNumber        Int
  rawData          Json
  normalizedData   Json
  processingStatus String    // "PENDING", "PROCESSED", "FAILED"
  importJob        ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
}

model ImportAnomaly {
  id               String    @id @default(uuid())
  importJobId      String
  rowNumber        Int
  rawData          Json      // The original CSV row data
  anomalyType      String    // e.g., "DUPLICATE", "MISSING_USER"
  severity         String    // "LOW", "MEDIUM", "HIGH"
  description      String
  suggestedAction  String?
  resolutionStatus String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  resolutionAction Json?     // The user's chosen fix
  resolutionNotes  String?
  reviewedAt       DateTime?
  reviewedById     String?
  importJob        ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  reviewer         User?     @relation("ReviewedAnomalies", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([importJobId, resolutionStatus])
}
